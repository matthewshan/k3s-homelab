{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  prHourlyLimit: 3,
  // Pin digests globally so ArgoCD detects manifest changes on image updates
  // instead of relying on imagePullPolicy: Always + manual pod deletions
  pinDigests: true,
  enabledManagers: [
    'helm-values',
    'kubernetes',
    'kustomize',
    'argocd',
  ],
  argocd: {
    managerFilePatterns: [
      '/^infrastructure/.+\\.yaml$/',
      '/^applications/.+\\.yaml$/',
      '/^services/.+\\.yaml$/',
    ],
  },
  kubernetes: {
    managerFilePatterns: [
      '/^infrastructure/.+\\.yaml$/',
      '/^applications/.+\\.yaml$/',
      '/^services/.+\\.yaml$/',
    ],
  },
  'helm-values': {
    managerFilePatterns: [
      '/^infrastructure/.+/values\\.yaml$/',
      '/^applications/.+/values\\.yaml$/',
      '/^services/.+/values\\.yaml$/',
    ],
  },
  kustomize: {
    managerFilePatterns: [
      '/(^|/)kustomization\\.ya?ml$/',
    ],
  },
  packageRules: [
    {
      // Auto-merge digest bumps for first-party images — these track :latest
      // and each digest change represents a new image push from CI
      matchPackagePatterns: ['^ghcr\\.io/matthewshan/'],
      matchUpdateTypes: ['digest'],
      automerge: true,
      automergeType: 'branch',
    },
    {
      matchUpdateTypes: [
        'minor',
        'patch',
        'digest',
      ],
      matchManagers: [
        'helm-values',
        'kubernetes',
        'kustomize',
        'argocd',
      ],
      automerge: true,
      automergeType: 'branch',
    },
    {
      matchUpdateTypes: [
        'major',
      ],
      matchManagers: [
        'helm-values',
        'kubernetes',
        'kustomize',
        'argocd',
      ],
      automerge: false,
      prCreation: 'immediate',
    },
  ],
  ignorePaths: [
    '**/charts/**',
  ],
}
